{
  "rewrites": [
    {
      "source": "/api/leads/:id",
      "destination": "/api/leads.js"
    },
    {
      "source": "/api/leads",
      "destination": "/api/leads.js"
    },
    {
      "source": "/api/webhook-lead/:token",
      "destination": "/api/webhook-lead.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
